# ==============================================================
# Albatross — 環境変数テンプレート
# ==============================================================
# このファイルをコピーして .env にリネームし、各値を設定してください。
# .env は .gitignore に含まれており、GitHubには上がりません。
# このファイル（.env.example）は値を空にした状態でGitHubに上げてください。
# ==============================================================

# --------------------------------------------------------------
# アプリケーション設定
# --------------------------------------------------------------

# Djangoのシークレットキー（必須）
# 生成方法: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# --------------------------------------------------------------
# データベース設定
# --------------------------------------------------------------

# PostgreSQLの接続URL（本番環境では自動設定される場合あり）
# 例: postgres://ユーザー名:パスワード@ホスト:5432/データベース名
DATABASE_URL=

# --------------------------------------------------------------
# 本番環境設定（Render）
# --------------------------------------------------------------

# RenderのサービスURL（CSRF_TRUSTED_ORIGINSの自動設定に使用）
# 例: https://albatross-w6pr.onrender.com
RENDER_EXTERNAL_URL=

# --------------------------------------------------------------
# ローカル開発環境では以下は不要です
# RenderにデプロイするとRENDERが自動で設定されます
# --------------------------------------------------------------

# RENDER=true  ← Renderが自動設定するため手動設定不要
