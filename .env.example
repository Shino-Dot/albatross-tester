# ==============================================================
# Albatross — 環境変数テンプレート
# ==============================================================
# このファイルをコピーして .env にリネームし、各値を設定してください。
# .env は .gitignore に含まれており、GitHubには上がりません。
# このファイル（.env.example）は値を空にした状態でGitHubに上げてください。
# ==============================================================

# --------------------------------------------------------------
# アプリケーション設定
# --------------------------------------------------------------

# Djangoのシークレットキー（必須）
# 生成方法: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# --------------------------------------------------------------
# データベース設定
# --------------------------------------------------------------

# PostgreSQLの接続URL（本番環境では自動設定される場合あり）
# 例: postgres://ユーザー名:パスワード@ホスト:5432/データベース名
DATABASE_URL=

# --------------------------------------------------------------
# 必須設定(テスター版)
# --------------------------------------------------------------

# Djangoのシークレットキー（任意の強力な文字列を設定してください）
# 例: python -c "from django.core.signing import get_cookie_signer; print(get_cookie_signer().key)" で生成可能
SECRET_KEY=

# データベース接続URL
# 例: postgresql://ユーザー名:パスワード@ホスト:5432/DB名
DATABASE_URL=

# --------------------------------------------------------------
# 本番環境設定
# --------------------------------------------------------------

# デプロイ先のURL（CSRF保護に使用）
# 例: https://your-app.onrender.com
CSRF_TRUSTED_ORIGINS=
